# Copiá este archivo a .env y completá los valores.
#   cp .env.example .env

# --- Usuario único del panel /admin (cambialos) ---
ADMIN_USER=admin
ADMIN_PASSWORD=cambia-esta-clave-por-una-fuerte

# --- Secreto para firmar la sesión (JWT) ---
# Generá uno largo y aleatorio, por ejemplo:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=reemplazá-por-un-secreto-largo-y-aleatorio

# --- Cookie segura ---
# false si servís por HTTP (puerto 80). true cuando tengas HTTPS.
COOKIE_SECURE=false

# --- Puerto público del sitio (host) ---
# 80 para producción y para apuntar el DNS más adelante.
HTTP_PORT=80
